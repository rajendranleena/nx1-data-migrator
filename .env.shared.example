# Shared environment configuration
# Copy to .env.shared and fill in actual values.
# It provides configuration for both Data Iceberg Migrator DAG and Ranger Policies Generator DAG.
# Only one copy should be present in the DAG folder.

# ==== Data Iceberg Migrator DAG ====

# S3 Configuration
MIGRATION_DEFAULT_S3_BUCKET=s3a://your-bucket/path
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# SSH Configuration
CLUSTER_SSH_CONN_ID=cluster_edge_ssh
CLUSTER_EDGE_TEMP_PATH=/tmp/migration

# DistCp Configuration
MIGRATION_DISTCP_MAPPERS=50
MIGRATION_DISTCP_BANDWIDTH=100

# Spark Configuration
MIGRATION_SPARK_CONN_ID=spark_default

# Cluster Authentication (MapR or Kerberos)
AUTH_METHOD=mapr
MAPR_USER=
MAPR_TICKETFILE_LOCATION=/tmp/maprticket_${USER}
KINIT_PRINCIPAL=
KINIT_KEYTAB=
KINIT_PASSWORD=

# Listing tool
S3_LISTING_TOOL=hadoop

# Email / SMTP Configuration
MIGRATION_SMTP_CONN_ID=smtp_default

# ==== Ranger Policies Generator DAG ====

# Ranger Configuration
RANGER_URL=http://ranger:6080
RANGER_USERNAME=
RANGER_PASSWORD=
NX1_REPO_NAME=nx1-unifiedsql

# Keycloak Configuration
KEYCLOAK_URL=
KEYCLOAK_REALM=
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=
KEYCLOAK_VERIFY_SSL=false
KEYCLOAK_CACERT=

# Spark Configuration
SPARK_CONN_ID=spark_default

# Email / SMTP Configuration
POLICY_SMTP_CONN_ID=smtp_default
