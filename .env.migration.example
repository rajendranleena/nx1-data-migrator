# Personal overrides for the Data Iceberg Migrator DAG
# Copy to .env.<your_dag_filename> (without .py)

MIGRATION_TRACKING_DATABASE=migration_tracking_<your_initials>
MIGRATION_TRACKING_LOCATION=s3a://your-bucket/migration_tracking_<your_initials>
MIGRATION_REPORT_LOCATION=s3a://your-bucket/migration_reports_<your_initials>
MIGRATION_EMAIL_RECIPIENTS=you@nexuscognitive.com
