# Personal overrides for the Ranger Policies Generator DAG
# Copy to env.<your_dag_filename> (without .py)

POLICY_TRACKING_DATABASE=policy_tracking_<your_initials>
POLICY_TRACKING_LOCATION=s3a://your-bucket/policy_tracking_<your_initials>
POLICY_REPORT_LOCATION=s3a://your-bucket/policy_reports_<your_initials>
POLICY_EMAIL_RECIPIENTS=you@nexuscognitive.com
