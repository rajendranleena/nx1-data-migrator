# SSH Configuration
CLUSTER_SSH_CONN_ID=cluster_edge_ssh
CLUSTER_EDGE_TEMP_PATH=/tmp/migration

# S3 Configuration
MIGRATION_DEFAULT_S3_BUCKET=s3a://data-lake
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# DistCp Configuration
MIGRATION_DISTCP_MAPPERS=50
MIGRATION_DISTCP_BANDWIDTH=100

# Spark Configuration
MIGRATION_SPARK_CONN_ID=spark_default

# Tracking Configuration
MIGRATION_TRACKING_DATABASE=migration_tracking
MIGRATION_TRACKING_LOCATION=s3a://data-lake/migration_tracking
MIGRATION_REPORT_LOCATION=s3a://data-lake/migration_reports

# Cluster Authentication (MapR or Kerberos)
AUTH_METHOD=mapr
MAPR_USER=
MAPR_TICKETFILE_LOCATION=/tmp/maprticket_${USER}
KINIT_PRINCIPAL=
KINIT_KEYTAB=
KINIT_PASSWORD=

# Listing tool
S3_LISTING_TOOL=hadoop

# Email / SMTP Configuration
MIGRATION_SMTP_CONN_ID=smtp_default
MIGRATION_EMAIL_RECIPIENTS=
